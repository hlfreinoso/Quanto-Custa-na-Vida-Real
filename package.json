{
  "name": "quanto-custa-na-vida-real",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo do app Quanto custa na vida real.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @quanto-custa/mobile run start",
    "android:mobile": "npm --workspace @quanto-custa/mobile run android",
    "ios:mobile": "npm --workspace @quanto-custa/mobile run ios",
    "web:mobile": "npm --workspace @quanto-custa/mobile run web",
    "lint": "echo \"No lint configured yet\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/core/tsconfig.json && tsc -p packages/ui/tsconfig.json && tsc -p apps/mobile/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
